# --- Security ---
# This hides your API key no matter which folder the .env file is in!
**/.env
.env

# --- Python Backend ---
# Hides the massive virtual environment and cache files
venv/
__pycache__/
*.pyc

# --- React Frontend ---
# Hides the heavy node_modules downloaded by npm
frontend/node_modules/
frontend/dist/

# --- OS Junk Files ---
.DS_Store
Thumbs.db